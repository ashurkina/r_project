library(tidyverse)
reviews <- read.csv("reviews.csv")
library(tidyverse)
# подготовка данных
reviews$score <- as.factor(reviews$score)
reviews$length <- as.numeric(reviews$length)
# график
ggplot(reviews, aes(x = score, y = length, fill = score)) +
geom_boxplot(
alpha = 0.8,
outlier.alpha = 0.4
) +
geom_jitter(
width = 0.2,
alpha = 0.15,
size = 1
) +
scale_fill_brewer(palette = "Blues") +
labs(
title = "Длина отзывов пользователей ChatGPT в зависимости от оценки",
subtitle = "Отзывы пользователей Google Play",
x = "Оценка приложения",
y = "Длина отзыва (символы)",
fill = "Оценка"
) +
theme_minimal(base_size = 14) +
theme(
legend.position = "none",
plot.title = element_text(
face = "bold",
size = 18
),
plot.subtitle = element_text(
size = 12,
color = "gray40"
)
)
ggplot(reviews, aes(x = score, y = length, fill = score)) +
geom_boxplot(
alpha = 0.95,
linewidth = 2,
outlier.color = "red",
outlier.size = 3
) +
geom_jitter(
color = "black",
width = 0.25,
alpha = 0.25,
size = 2
) +
scale_fill_manual(values = c(
"hotpink",
"cyan",
"yellow",
"limegreen",
"orange"
)) +
labs(
title = "EXTREME CHATGPT USER EXPERIENCE ANALYTICS",
subtitle = "next generation AI-powered blockchain emotional dashboard",
x = "USER SCORE CATEGORY",
y = "TEXT LENGTH MEASUREMENT SYSTEM",
fill = "RATING ENERGY"
) +
theme_minimal(base_size = 18) +
theme(
panel.background = element_rect(fill = "black"),
plot.background = element_rect(fill = "hotpink"),
panel.grid.major = element_line(
color = "yellow",
linewidth = 1.5
),
panel.grid.minor = element_line(
color = "cyan",
linewidth = 0.7
),
text = element_text(
face = "bold",
color = "white"
),
axis.text.x = element_text(
angle = 45,
hjust = 1,
color = "cyan",
size = 16
),
axis.text.y = element_text(
color = "yellow",
size = 16
),
axis.title = element_text(
color = "limegreen",
size = 22
),
plot.title = element_text(
size = 28,
color = "limegreen"
),
plot.subtitle = element_text(
size = 16,
color = "orange"
),
legend.position = "bottom"
)
